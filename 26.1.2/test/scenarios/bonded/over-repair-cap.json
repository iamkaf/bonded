      "z": 0,
      "direction": "up",
      "hand": "main_hand"
    },
    {
      "action": "use_block_server",
      "x": 0,
      "y": 71,
      "z": 0,
      "direction": "up",
      "hand": "main_hand"
    },
    {
      "action": "use_block_server",
      "x": 0,
      "y": 71,
      "z": 0,
      "direction": "up",
      "hand": "main_hand"
    },
    {
      "action": "use_block_server",
      "x": 0,
      "y": 71,
      "z": 0,
      "direction": "up",
      "hand": "main_hand"
    },
